# Norani Portal — Environment Variables
# Copy this file to .env and fill in real values

# ============ APP ============
APP_NAME="Norani Portal API"
ENVIRONMENT=development
DEBUG=true

# ============ DATABASE ============
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://norani_portal:changeme@localhost:5432/norani_portal
# Sync URL (used by Alembic) — same DB, different driver
DATABASE_URL_SYNC=postgresql+psycopg2://norani_portal:changeme@localhost:5432/norani_portal

# ============ JWT ============
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-64-char-hex-string-from-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============ APPKEY ENCRYPTION ============
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APPKEY_ENCRYPTION_KEY=replace-with-fernet-key

# ============ CHIRPSTACK ============
CHIRPSTACK_API_URL=localhost:8080
# Generate in ChirpStack UI under Tenant → API Keys (admin key)
CHIRPSTACK_API_TOKEN=replace-with-chirpstack-admin-token

# ============ INFLUXDB ============
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=replace-with-influxdb-token
INFLUXDB_ORG=norani
INFLUXDB_BUCKET=lorawan-data

# ============ CORS ============
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,https://portal.norani.rw

# ============ PRICING ============
# Default price per device per month in RWF (used for new customers)
DEFAULT_PRICE_PER_DEVICE_RWF=1500
